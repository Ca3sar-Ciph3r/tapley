# Tapley Connect — Environment Variables
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to git.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# WARNING: Service role key bypasses RLS. NEVER expose to the browser.
# Only used server-side in: /api/view-event, /c/[slug], super admin ops.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tapleyconnect.co.za

# ── Make.com Webhooks ─────────────────────────────────────────────────────────
# Fired server-side from API routes. Never exposed to browser.
MAKE_WEBHOOK_VIEW_EVENT=https://hook.eu1.make.com/your-webhook-id
MAKE_WEBHOOK_CONTACT_CAPTURED=https://hook.eu1.make.com/your-webhook-id

# ── Resend (Transactional Email) ──────────────────────────────────────────────
# Found in: resend.com → API Keys
# Used for onboarding drip emails and monthly digests. Never expose to browser.
RESEND_API_KEY=re_your_api_key_here

# ── Notifications ─────────────────────────────────────────────────────────────
# Email address to notify when a referral is created via createCompany.
# Set this to your own email (e.g. lukegunn90@gmail.com).
SUPER_ADMIN_NOTIFY_EMAIL=lukegunn90@gmail.com
